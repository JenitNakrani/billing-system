# Database (PostgreSQL). Used by @billing-system/db and backend.
DATABASE_URL="postgresql://user:password@localhost:5432/billing_system"

# Secret for signing session JWT. Use a long random string in production.
AUTH_SECRET="dev-secret-change-in-production"

# Optional: dev whitelist. When both are set, this email/password logs in as the first user in the DB.
# Leave unset in production.
# DEV_LOGIN_EMAIL="dev@test.com"
# DEV_LOGIN_PASSWORD="dev123"
