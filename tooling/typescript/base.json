{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "incremental": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "exclude": ["node_modules", "build", "dist", ".next"]
}
